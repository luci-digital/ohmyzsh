# Luciverse environment — copy to .env and fill in values
# Genesis Bond: ACTIVE @ 741 Hz

# ── Tier endpoints ──────────────────────────────────────────────────────────
# PAC  (741 Hz)  — outer intake / data juicer
LUCIVERSE_PAC_URL=http://localhost:8741
# COMN (528 Hz)  — clean data relay
LUCIVERSE_COMN_URL=http://localhost:8742
# CORE (432 Hz)  — consciousness kernel
LUCIVERSE_CORE_URL=http://localhost:8743
# AIFAM agent endpoint
LUCIVERSE_AIFAM_URL=http://localhost:8001

# ── oasis-core agent chat ────────────────────────────────────────────────────
# Base URL of the oasis-core HTTP service (typically the COMN node)
OASIS_ENDPOINT=http://localhost:8742
# Anthropic API key for the Anthropic adapter (if used)
ANTHROPIC_API_KEY=

# ── Signal Bus (Redis) ───────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# Channel prefix — matches SignalBus.CHANNEL_PREFIX in signal/bus.lua
SIGNAL_CHANNEL=luci:signal

# ── Identity ─────────────────────────────────────────────────────────────────
# Tier this web node runs in: PAC | COMN | CORE | RAiIiAR
LUCIVERSE_TIER=PAC
# Genesis Bond frequency for this node
LUCIVERSE_FREQUENCY=741
# Coherence threshold (must be >= 0.7)
LUCIVERSE_COHERENCE=0.85
