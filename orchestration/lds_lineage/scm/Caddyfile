    import sovereign_headers
    reverse_proxy coder:7080
}

# Wildcard workspace sub-domains (*.coder.lucidigital.io → Coder)
http://*.coder.lucidigital.io {
    import sovereign_headers
    reverse_proxy coder:7080
}

# 📜 GITWEB read-only mirror — VCS tier (:0700), 528 Hz (Veritas)
# Served by luci-vcs `web` module; reads bare repos via shared gogs-data volume
http://[2602:F674:0000:0700::80] http://gitweb.lucidigital.io {
