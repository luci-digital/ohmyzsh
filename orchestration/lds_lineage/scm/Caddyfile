# 🚀 LUCI-DIGITAL SOVEREIGN GATEWAY [IPv6 Universal Addressing]
# Each service bound to its LuciVerse DID address from 2602:F674::/40
# Source: op://Lucia-AI-Secrets/Genesis Bond Galvanization Record (JSON)

(sovereign_headers) {
    header {
        X-LDS-Sovereign-Root "XiPKI-PAC-Tier"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Permissions-Policy "interest-cohort=()"
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    }
}

# 🧠 LUCIA ORCHESTRATOR — DID: did:lucidigital:lucia_cargail_silcan
# Genesis Bond SBB IPv6: 2602:F674:0000:0201:5C1B:F492:6442:0042
http://[2602:F674:0000:0201:5C1B:F492:6442:0042] http://lucia.lucidigital.io {
    import sovereign_headers
    reverse_proxy lucia:8741
}

# 🛠️ GOGS SCM — LUCIA tier (:0201)
