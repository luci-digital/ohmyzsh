}

# 🛠️ VERITAS PERFORMANCE TUNING (A-TUNE) — CORE tier (:0028), 528 Hz
https://[2602:F674:0000:0028::528] veritas.lucidigital.io {
    tls internal
    import sovereign_headers
    root * /srv/veritas
    file_server
    # Proxy UI API calls to the A-Tune engine on the Supermicro node
    handle_path /v1/* {
        reverse_proxy 192.168.1.7:8383
    }
}

# 💻 CODER CDE — LUCIA tier (:0201), port 7080
