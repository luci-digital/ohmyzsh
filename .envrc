# direnv — auto-load the Nix dev shell on `cd` into the repo.
# Requires direnv (https://direnv.net) + nix-direnv for caching.
use flake

# Load local, uncommitted secrets if present (see modules/infra/secrets/env.example).
# .env is gitignored and must never be committed.
if [ -f .env ]; then
  dotenv .env
fi

watch_file flake.nix flake.lock
